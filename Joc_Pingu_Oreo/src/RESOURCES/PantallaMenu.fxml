<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root" stylesheets="@PantallaMenu.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="VISTA.PantallaMenu">
    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame" mnemonicParsing="false" onAction="#handleNewGame" text="New" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" onAction="#handleSaveGame" text="Save" />
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" onAction="#handleLoadGame" text="Load" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" onAction="#handleQuitGame" text="Quit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane prefHeight="700.0" prefWidth="1000.0">
            <padding>
                <Insets bottom="28" left="28" right="28" top="28" />
            </padding>

            <VBox maxWidth="420" spacing="16" style="-fx-background-color: rgba(255, 255, 255, 0.6);;" styleClass="card">
                <padding>
                    <Insets bottom="18" left="18" right="18" top="18" />
                </padding>

                <!-- Cabecera -->
                <VBox alignment="CENTER" prefHeight="48.0" prefWidth="394.0" spacing="6" style="-fx-background-color: rgba(255, 255, 255, 0.4); -fx-background-radius: 15;">
                    <Label styleClass="title" text="EL JUEGO DEL PINGÜINO" wrapText="true" />
                </VBox>

                <Region prefHeight="8" />

                <!-- Formulario -->
                <VBox spacing="10">
                    <Label styleClass="field-label" text="Usuario" />
                    <TextField fx:id="userField" promptText="Usuario..." styleClass="field" />

                    <Label styleClass="field-label" text="Contraseña" />
                    <PasswordField fx:id="passField" promptText="Contraseña..." styleClass="field" />
                </VBox>

                <Region prefHeight="6" />

                <!-- Botonera -->
                <HBox spacing="10">
                    <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" styleClass="primary" text="Login" />
                    <Button fx:id="registerButton" maxWidth="Infinity" onAction="#handleRegister" text="Registro" />
                </HBox>

                <Label styleClass="hint" text="Tip: para la demo, puedes entrar con cualquier usuario si aún no hay validación." wrapText="true" />
            </VBox>
        </StackPane>
    </center>

</BorderPane>
