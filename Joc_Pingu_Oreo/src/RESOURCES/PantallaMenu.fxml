<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    xmlns="http://javafx.com/javafx/21.0.10"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.PantallaMenu"
    stylesheets="@PantallaMenu.css"
    styleClass="root">

    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame" mnemonicParsing="false" text="New" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" text="Save" />
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" text="Load" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" text="Quit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets top="28" right="28" bottom="28" left="28"/>
            </padding>

            <VBox spacing="16" styleClass="card" maxWidth="420">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <!-- Cabecera -->
                <VBox spacing="6" alignment="CENTER">
                    <Label text="EL JUEGO DEL PINGÜINO" styleClass="title" wrapText="true"/>
                </VBox>

                <Region prefHeight="8"/>

                <!-- Formulario -->
                <VBox spacing="10">
                    <Label text="Usuario" styleClass="field-label"/>
                    <TextField fx:id="userField" promptText="Usuario..." styleClass="field"/>

                    <Label text="Contraseña" styleClass="field-label"/>
                    <PasswordField fx:id="passField" promptText="Contraseña..." styleClass="field"/>
                </VBox>

                <Region prefHeight="6"/>

                <!-- Botonera -->
                <HBox spacing="10">
                    <Button fx:id="loginButton" text="Login" onAction="#handleLogin" maxWidth="Infinity" styleClass="primary"/>
                    <Button fx:id="registerButton" text="Registro" onAction="#handleRegister" maxWidth="Infinity"/>
                </HBox>

                <Label text="Tip: para la demo, puedes entrar con cualquier usuario si aún no hay validación."
                       styleClass="hint" wrapText="true"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>